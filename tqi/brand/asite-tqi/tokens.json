{
  "$schema": "https://design-tokens.org/format",
  "$description": "Asite — The Quiet Instrument (Direction 02). Design tokens, W3C draft format. Machine-readable mirror of the live CSS source of truth: tqi/tokens.css (dark) and tqi/light/tokens.css (light). Survey Orange is the system's ONLY accent hue, used with restraint — status and banners are functional colours, not accents. Depth from borders + light, never fills.",
  "$meta": {
    "name": "asite-tqi",
    "version": "1.1.0",
    "accent": "#FF5C26",
    "idiom": "Linear",
    "source": "https://cnasite.github.io/visual_lang/tqi/",
    "css": "tqi/tokens.css · tqi/light/tokens.css"
  },

  "color": {
    "dark": {
      "surface": {
        "bg-0": { "$type": "color", "$value": "#08090A", "$description": "canvas" },
        "bg-1": { "$type": "color", "$value": "#0F1011", "$description": "app chrome, sidebars" },
        "bg-2": { "$type": "color", "$value": "#141517", "$description": "cards, popovers" },
        "bg-3": { "$type": "color", "$value": "#1A1B1E", "$description": "hover, raised" },
        "bg-overlay": { "$type": "color", "$value": "rgba(8,9,10,0.6)" }
      },
      "border": {
        "border": { "$type": "color", "$value": "rgba(255,255,255,0.08)" },
        "border-strong": { "$type": "color", "$value": "rgba(255,255,255,0.14)" }
      },
      "text": {
        "text-1": { "$type": "color", "$value": "#F7F8F8", "$description": "primary" },
        "text-2": { "$type": "color", "$value": "#8A8F98", "$description": "secondary" },
        "text-3": { "$type": "color", "$value": "#62666D", "$description": "tertiary, placeholders" }
      },
      "intent": {
        "intent": { "$type": "color", "$value": "#FF5C26", "$description": "Survey Orange — the only accent hue; use with restraint" },
        "intent-bright": { "$type": "color", "$value": "#FF7A4D", "$description": "hover, links" },
        "intent-wash": { "$type": "color", "$value": "rgba(255,92,38,0.13)", "$description": "tint, selected rows, focus rings" }
      },
      "status": {
        "done": { "$type": "color", "$value": "#4CB782" },
        "progress": { "$type": "color", "$value": "#D4A444" },
        "blocked": { "$type": "color", "$value": "#EB6E6E" },
        "review": { "$type": "color", "$value": "#7FA3BC" },
        "backlog": { "$type": "color", "$value": "#62666D" }
      }
    },
    "light": {
      "surface": {
        "bg-0": { "$type": "color", "$value": "#F6F6F4", "$description": "canvas" },
        "bg-1": { "$type": "color", "$value": "#FFFFFF", "$description": "app chrome, sidebars" },
        "bg-2": { "$type": "color", "$value": "#FBFBFA", "$description": "cards, popovers" },
        "bg-3": { "$type": "color", "$value": "#EEEEEB", "$description": "hover, raised" },
        "bg-overlay": { "$type": "color", "$value": "rgba(22,24,28,0.35)" }
      },
      "border": {
        "border": { "$type": "color", "$value": "rgba(22,24,28,0.10)" },
        "border-strong": { "$type": "color", "$value": "rgba(22,24,28,0.18)" }
      },
      "text": {
        "text-1": { "$type": "color", "$value": "#16181C", "$description": "primary" },
        "text-2": { "$type": "color", "$value": "#5A5F66", "$description": "secondary" },
        "text-3": { "$type": "color", "$value": "#90949B", "$description": "tertiary, placeholders" }
      },
      "intent": {
        "intent": { "$type": "color", "$value": "#E8501C", "$description": "Survey Orange (light) — the only accent hue; use with restraint" },
        "intent-bright": { "$type": "color", "$value": "#FF5C26", "$description": "hover, links" },
        "intent-wash": { "$type": "color", "$value": "rgba(232,80,28,0.10)" }
      },
      "status": {
        "done": { "$type": "color", "$value": "#2E9E68" },
        "progress": { "$type": "color", "$value": "#B98A1D" },
        "blocked": { "$type": "color", "$value": "#D8504F" },
        "review": { "$type": "color", "$value": "#5C84A0" },
        "backlog": { "$type": "color", "$value": "#90949B" }
      }
    }
  },

  "font": {
    "family": {
      "display": { "$type": "fontFamily", "$value": ["Cornerstone", "Inter", "sans-serif"], "$description": "Hero + slide titles ONLY" },
      "ui": { "$type": "fontFamily", "$value": ["Inter", "Segoe UI", "sans-serif"], "$description": "Headings, body, all UI" },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "SF Mono", "monospace"], "$description": "Engineering alphanumerics, labels" }
    },
    "scale": {
      "display": { "$type": "typography", "$value": { "fontFamily": "display", "fontWeight": 400, "fontSize": "58px", "lineHeight": 1.1, "fluid": "clamp(38px,4.6vw,58px)", "letterSpacing": "0.015em" } },
      "h1": { "$type": "typography", "$value": { "fontFamily": "ui", "fontWeight": 590, "fontSize": "34px", "lineHeight": 1.15, "letterSpacing": "-0.012em" } },
      "h2": { "$type": "typography", "$value": { "fontFamily": "ui", "fontWeight": 560, "fontSize": "22px", "lineHeight": 1.25 } },
      "h3": { "$type": "typography", "$value": { "fontFamily": "ui", "fontWeight": 560, "fontSize": "16px", "lineHeight": 1.35 } },
      "body": { "$type": "typography", "$value": { "fontFamily": "ui", "fontWeight": 400, "fontSize": "15px", "lineHeight": 1.6 } },
      "small": { "$type": "typography", "$value": { "fontFamily": "ui", "fontWeight": 400, "fontSize": "13px", "lineHeight": 1.55 } },
      "micro": { "$type": "typography", "$value": { "fontFamily": "ui", "fontWeight": 500, "fontSize": "11px", "lineHeight": 1.4, "letterSpacing": "0.02em" } },
      "mono": { "$type": "typography", "$value": { "fontFamily": "mono", "fontWeight": 400, "fontSize": "12.5px", "lineHeight": 1.5 } }
    }
  },

  "radius": {
    "sm": { "$type": "dimension", "$value": "6px" },
    "md": { "$type": "dimension", "$value": "8px" },
    "lg": { "$type": "dimension", "$value": "12px" },
    "xl": { "$type": "dimension", "$value": "16px" }
  },

  "space": {
    "1": { "$type": "dimension", "$value": "4px" }, "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" }, "4": { "$type": "dimension", "$value": "16px" },
    "6": { "$type": "dimension", "$value": "24px" }, "8": { "$type": "dimension", "$value": "32px" },
    "12": { "$type": "dimension", "$value": "48px" }, "16": { "$type": "dimension", "$value": "64px" },
    "24": { "$type": "dimension", "$value": "96px" }
  },

  "effect": {
    "dark": {
      "inset": { "$type": "shadow", "$value": "inset 0 0 0 1px rgba(255,255,255,0.06)" },
      "shadow-card": { "$type": "shadow", "$value": "0 8px 32px rgba(0,0,0,0.35)" },
      "shadow-pop": { "$type": "shadow", "$value": "0 16px 64px rgba(0,0,0,0.55)" },
      "intent-glow": { "$type": "shadow", "$value": "0 0 0 1px rgba(255,92,38,0.4), 0 0 24px rgba(255,92,38,0.22)" }
    },
    "light": {
      "inset": { "$type": "shadow", "$value": "inset 0 0 0 1px rgba(22,24,28,0.07)" },
      "shadow-card": { "$type": "shadow", "$value": "0 8px 28px rgba(22,24,28,0.08)" },
      "shadow-pop": { "$type": "shadow", "$value": "0 16px 56px rgba(22,24,28,0.14)" },
      "intent-glow": { "$type": "shadow", "$value": "0 0 0 1px rgba(232,80,28,0.35), 0 0 24px rgba(232,80,28,0.14)" }
    }
  },

  "motion": {
    "ease": { "$type": "cubicBezier", "$value": [0.25, 0.1, 0.25, 1] },
    "duration-fast": { "$type": "duration", "$value": "80ms" },
    "duration-base": { "$type": "duration", "$value": "140ms" }
  },

  "ai": {
    "$description": "The Intelligence layer. No new colours — it reuses intent + status. See the AI Hub page for live patterns.",
    "mark": {
      "spark": { "$type": "other", "$value": "four-point star (the setting-out cross sharpened); filled intent when live, 1.4px gray line when quiet" },
      "orb": { "$type": "other", "$value": "spark at the datum of concentric survey rings; entry points, avatars, hero" }
    },
    "idle-glow": {
      "$type": "shadow",
      "$value": "0 0 22px 3px rgba(255,92,38,0.16)",
      "$description": "soft breathing halo on the entry orb at idle; opacity 0.4->1 over 4.5s; static under prefers-reduced-motion. Never harsh."
    },
    "run-state": {
      "$description": "Dot-first, mapped to existing status hues. Only running/streaming animate (intent pulse).",
      "queued": { "$type": "color", "$value": "{color.*.status.backlog}" },
      "running": { "$type": "color", "$value": "{color.*.intent.intent}", "$description": "pulses" },
      "streaming": { "$type": "color", "$value": "{color.*.intent.intent}", "$description": "pulses" },
      "waiting": { "$type": "color", "$value": "{color.*.status.progress}" },
      "blocked": { "$type": "color", "$value": "{color.*.status.blocked}" },
      "done": { "$type": "color", "$value": "{color.*.status.done}" },
      "error": { "$type": "color", "$value": "{color.*.status.blocked}" }
    },
    "modes": {
      "side-chat": "Summoned. Floating orb + 'Ask Asite Intelligence' pill, opens a docked conversation panel. ACL-scoped, assistive, cites sources.",
      "coworker": "Embedded in a task (upload, form, drawing, bid). Runs steps and returns a reviewable, field-level result. Nothing applied until the user says so."
    }
  }
}
