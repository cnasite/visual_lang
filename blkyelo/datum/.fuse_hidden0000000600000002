<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Asite — Measured from one line</title>
<link rel="stylesheet" href="tokens.css">
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body { background:var(--bg-0); color:var(--t2); font:var(--text-body); -webkit-font-smoothing:antialiased; }
  ::selection { background:var(--yel-soft); color:var(--t1); }
  img { display:block; max-width:100%; }
  a { color:inherit; }
  .wrap { max-width:1140px; margin:0 auto; padding:0 var(--s6); }
  .m-body { fill:var(--t1); } .m-arrow { fill:var(--yel); }
  .stencil { font:var(--text-stencil); letter-spacing:var(--track-mono); text-transform:uppercase; color:var(--t3); }

  /* buttons */
  .btn { display:inline-flex; align-items:center; gap:9px; font:500 13.5px/1 var(--font-ui); padding:13px 22px; border:1px solid transparent; border-radius:var(--r-md); cursor:pointer; text-decoration:none; }
  .btn-primary { background:var(--yel); color:var(--bg-0); } .btn-primary:hover { background:var(--yel-bright); }
  .btn-line { background:none; color:var(--yel); border-color:var(--yel); } .btn-line:hover { background:var(--yel-soft); }
  .btn-ghost { background:none; color:var(--t1); border-bottom:1px solid var(--yel); border-radius:0; padding:13px 2px; }

  /* nav */
  nav { position:sticky; top:0; z-index:60; background:rgba(10,10,8,0.84); backdrop-filter:blur(16px); border-bottom:1px solid var(--border); }
  nav .wrap { display:flex; align-items:center; gap:var(--s4); height:60px; }
  .word { display:flex; align-items:center; gap:10px; font:590 16px/1 var(--font-ui); letter-spacing:-0.01em; color:var(--t1); text-decoration:none; margin-right:var(--s4); }
  nav .lnk { font:500 13px/1 var(--font-ui); color:var(--t2); text-decoration:none; } nav .lnk:hover { color:var(--t1); }
  nav .sp { margin-left:auto; display:flex; align-items:center; gap:var(--s4); }

  /* hero */
  .hero { position:relative; padding:96px 0 76px; border-bottom:1px solid var(--border-soft); overflow:hidden; }
  .hero .ey { color:var(--yel); margin-bottom:var(--s4); display:inline-flex; align-items:center; gap:9px; }
  .hero .ey::before { content:""; width:6px; height:6px; border:1px solid var(--yel); transform:rotate(45deg); }
  .hero h1 { font:var(--text-display); letter-spacing:var(--track-tight); color:var(--t1); max-width:780px; }
  .hero h1 em { font-style:normal; color:var(--yel); }
  .hero .sub { margin-top:var(--s6); max-width:540px; font:400 17px/1.7 var(--font-ui); color:var(--t2); }
  .hero .cta { margin-top:var(--s8); display:flex; gap:var(--s4); align-items:center; }
  .hero .datum { position:relative; margin-top:var(--s12); height:1px; background:var(--yel); }
  .hero .datum::before, .hero .datum::after { content:""; position:absolute; top:-4px; width:9px; height:9px; border:1px solid var(--yel); transform:rotate(45deg); background:var(--bg-0); }
  .hero .datum::before { left:0; } .hero .datum::after { right:0; }
  .hero .ticks { display:flex; justify-content:space-between; margin-top:10px; font:var(--text-mono); color:var(--t3); letter-spacing:0.08em; }

  /* annotated image band */
  .bleed { position:relative; margin-top:var(--s12); border:1px solid var(--border-soft); border-radius:var(--r-md); overflow:hidden; min-height:340px; }
  .bleed img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
  .bleed .ann { position:absolute; left:0; right:0; bottom:48px; height:1px; background:var(--yel); }
  .bleed .ann::before { content:""; position:absolute; left:24px; top:-4px; width:9px; height:9px; border:1px solid var(--yel); transform:rotate(45deg); background:rgba(10,10,8,0.7); }
  .bleed .tk { position:absolute; left:24px; bottom:20px; font:var(--text-mono); font-size:10px; color:var(--yel); letter-spacing:0.1em; }

  /* section shell */
  section { padding:var(--s24) 0; border-bottom:1px solid var(--border-soft); }
  .shead .ey { color:var(--yel); margin-bottom:var(--s3); }
  .shead h2 { font:var(--text-h1); letter-spacing:var(--track-h); color:var(--t1); }
  .shead h2 em { font-style:normal; color:var(--yel); }
  .shead p { font:400 15px/1.7 var(--font-ui); color:var(--t2); max-width:540px; margin-top:var(--s3); }

  /* proof */
  .proof { padding:var(--s8) 0; border-bottom:1px solid var(--border-soft); }
  .proof .wrap { display:flex; align-items:center; gap:var(--s8); }
  .proof .big { flex:none; font:500 17px/1.3 var(--font-ui); color:var(--t1); white-space:nowrap; }
  .proof .big em { font-style:normal; color:var(--yel); }
  .proof .names { flex:1; display:flex; align-items:center; justify-content:space-between; gap:var(--s6); }
  .proof .names img { height:24px; max-width:120px; object-fit:contain; opacity:0.55; filter:grayscale(1); }

  /* product sections */
  .prod { display:grid; grid-template-columns:0.9fr 1.1fr; gap:var(--s8); padding:var(--s16) 0; border-bottom:1px solid var(--border-soft); align-items:center; }
  .prod.rev .pt { order:2; }
  .prod .pt .ey { color:var(--yel); margin-bottom:var(--s3); }
  .prod .pt h3 { font:560 26px/1.15 var(--font-ui); letter-spacing:var(--track-h); color:var(--t1); }
  .prod .pt p { font:400 14px/1.65 var(--font-ui); color:var(--t2); margin-top:var(--s3); max-width:380px; }
  .prod .pt ul { list-style:none; margin-top:var(--s4); display:flex; flex-direction:column; gap:11px; }
  .prod .pt li { display:flex; gap:11px; font:400 13.5px/1.4 var(--font-ui); color:var(--t1); }
  .prod .pt li::before { content:""; width:11px; height:11px; border:1px solid var(--yel); transform:rotate(45deg); flex:none; margin-top:3px; }

  /* instrument product mock */
  .pm { border:1px solid var(--border); border-radius:var(--r-md); background:var(--bg-1); overflow:hidden; }
  .pm .bar { display:flex; align-items:center; gap:7px; padding:10px 13px; border-bottom:1px solid var(--border-soft); }
  .pm .bar i { width:6px; height:6px; border:1px solid var(--t3); } .pm .bar i.y { border-color:var(--yel); }
  .pm .bar .u { margin-left:8px; font:var(--text-mono); font-size:10px; color:var(--t3); letter-spacing:0.06em; }
  .pm .body { padding:16px; }
  .pm .read { display:flex; border:1px solid var(--border-soft); border-radius:var(--r-sm); }
  .pm .read .k { flex:1; padding:14px; border-left:1px solid var(--border-soft); } .pm .read .k:first-child { border-left:none; }
  .pm .read .v { font:400 28px/0.9 var(--font-ui); letter-spacing:-0.02em; color:var(--t1); } .pm .read .v.hot { color:var(--yel); }
  .pm .read .l { font:var(--text-mono); font-size:9px; color:var(--t3); margin-top:8px; letter-spacing:0.06em; }
  .pm .pr { display:flex; align-items:center; gap:10px; padding:11px 0; border-top:1px solid var(--border-soft); }
  .pm .pr:first-of-type { margin-top:12px; }
  .pm .pr .rf { font:var(--text-mono); font-size:11px; color:var(--yel); width:84px; flex:none; }
  .pm .pr .rf.dim { color:var(--t3); }
  .pm .pr .t { font:400 12.5px/1.3 var(--font-ui); color:var(--t1); }
  .pm .pr .d { margin-left:auto; display:inline-flex; align-items:center; gap:6px; font:var(--text-mono); font-size:9.5px; color:var(--t2); border:1px solid var(--border); border-radius:var(--r-sm); padding:4px 7px; }
  .pm .fr { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
  .pm .ff { border:1px solid var(--border-soft); border-radius:var(--r-sm); padding:11px; } .pm .ff b { display:block; font:500 11.5px/1.3 var(--font-ui); color:var(--t1); margin-top:8px; } .pm .ff span { font:var(--text-mono); font-size:9px; color:var(--t3); }
  .pm .gl { width:26px; height:1px; background:var(--yel); margin-bottom:6px; } .pm .gl.v { width:1px; height:18px; }
  .pm .mrow { padding:9px 0; border-top:1px solid var(--border-soft); } .pm .mrow .l1 { display:flex; gap:8px; font:500 12px/1.3 var(--font-ui); color:var(--t1); } .pm .mrow .l1 .tm { margin-left:auto; font:var(--text-mono); font-size:9px; color:var(--t3); } .pm .mrow .l2 { font:400 11px/1.4 var(--font-ui); color:var(--t2); margin-top:3px; }
  .pm .chip { display:inline-block; font:var(--text-mono); font-size:8.5px; letter-spacing:0.05em; color:var(--yel); border:1px solid var(--border); border-radius:var(--r-sm); padding:3px 6px; margin-top:5px; }

  /* numbers — instrument readout */
  .nums { display:flex; border:1px solid var(--border-soft); border-radius:var(--r-md); margin:var(--s8) 0; }
  .nums .nm { flex:1; padding:var(--s8) var(--s6); border-left:1px solid var(--border-soft); }
  .nums .nm:first-child { border-left:none; }
  .nums .nm .v { font:400 clamp(36px,4.4vw,56px)/0.9 var(--font-display); letter-spacing:-0.03em; color:var(--t1); }
  .nums .nm .v em { font-style:normal; color:var(--yel); }
  .nums .nm .l { font:var(--text-mono); font-size:10px; color:var(--t3); margin-top:12px; letter-spacing:0.05em; }

  /* reel */
  .reel-wrap { margin-top:var(--s8); border:1px solid var(--border); border-radius:var(--r-md); overflow:hidden; }
  .vid { position:relative; background:var(--bg-1); }
  .stage { position:relative; aspect-ratio:16/8; display:flex; align-items:center; justify-content:center; overflow:hidden; }
  .reel { position:absolute; inset:0; background:#0A0A08; }
  .frame { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:0; transition:opacity 1.1s var(--ease); }
  .frame.on { opacity:1; }
  .vgrad { position:absolute; inset:0; z-index:2; pointer-events:none; opacity:0; transition:opacity var(--t-base) var(--ease); background:radial-gradient(130% 90% at 50% 40%, transparent 40%, rgba(10,10,8,0.7) 100%); }
  .vid:hover .vgrad, .vid:focus-within .vgrad { opacity:1; }
  .play { position:relative; z-index:3; width:74px; height:74px; border-radius:50%; border:1px solid var(--yel); background:var(--yel-soft); cursor:pointer; display:flex; align-items:center; justify-content:center; opacity:0; transition:opacity var(--t-base) var(--ease), transform var(--t-base) var(--ease); }
  .vid:hover .play, .vid:focus-within .play { opacity:1; } .vid:hover .play:hover { transform:scale(1.06); }
  .play::after { content:""; width:0; height:0; margin-left:5px; border-top:11px solid transparent; border-bottom:11px solid transparent; border-left:18px solid var(--yel); }
  .vid.playing .play::after { width:5px; height:18px; margin:0; border:none; background:var(--yel); box-shadow:9px 0 0 var(--yel); transform:translateX(-4px); }
  .vbar { display:flex; align-items:center; gap:var(--s3); padding:14px var(--s4); border-top:1px solid var(--border-soft); }
  .vbar b { font:500 13px/1 var(--font-ui); color:var(--t1); } .vbar .mn { font:var(--text-mono); font-size:10px; color:var(--t3); letter-spacing:0.08em; }
  .vbar .track { margin-left:auto; flex:0 0 240px; height:1px; background:var(--border); } .vbar .track i { display:block; height:1px; width:0; background:var(--yel); }
  @media (prefers-reduced-motion: reduce){ .frame.on { animation:none; } }

  /* quote */
  .quote { position:relative; padding:var(--s12) 0 var(--s12) var(--s8); }
  .quote .bar { position:absolute; left:0; top:var(--s12); bottom:var(--s12); width:1px; background:var(--yel); }
  .quote .bar::before, .quote .bar::after { content:""; position:absolute; left:-4px; width:9px; height:9px; border:1px solid var(--yel); transform:rotate(45deg); background:var(--bg-0); }
  .quote .bar::before { top:-4px; } .quote .bar::after { bottom:-4px; }
  .quote blockquote { font:400 clamp(24px,3vw,38px)/1.25 var(--font-ui); letter-spacing:-0.01em; color:var(--t1); max-width:20ch; }
  .quote blockquote em { font-style:normal; color:var(--yel); }
  .quote .by { display:flex; align-items:center; gap:12px; margin-top:var(--s6); }
  .quote .by .ln { width:32px; height:1px; background:var(--yel); } .quote .by span { font:var(--text-mono); font-size:11px; letter-spacing:0.07em; color:var(--t2); }

  /* cases */
  .cases { display:grid; grid-template-columns:1fr 1fr; gap:var(--s4); margin-top:var(--s8); }
  .case { border:1px solid var(--border-soft); border-radius:var(--r-md); overflow:hidden; }
  .case .ph { position:relative; aspect-ratio:16/9; overflow:hidden; }
  .case .ph img { width:100%; height:100%; object-fit:cover; }
  .case .ph .tag { position:absolute; left:0; bottom:0; font:var(--text-mono); font-size:9.5px; letter-spacing:0.1em; color:var(--yel); background:rgba(10,10,8,0.66); padding:5px 9px; }
  .case .ph .ann { position:absolute; left:0; right:0; bottom:30px; height:1px; background:var(--yel); opacity:0.85; }
  .case .body { padding:var(--s6); }
  .case h3 { font:560 19px/1.3 var(--font-ui); letter-spacing:var(--track-h); color:var(--t1); margin-bottom:var(--s2); }
  .case p { font:400 13.5px/1.7 var(--font-ui); color:var(--t2); }
  .case .who { display:flex; align-items:center; gap:11px; margin-top:var(--s4); } .case .who i { width:30px; height:1px; background:var(--yel); } .case .who span { font:var(--text-mono); font-size:10.5px; letter-spacing:0.07em; color:var(--t2); }

  /* cta */
  .cta-band { position:relative; padding:var(--s24) 0; border-bottom:1px solid var(--border-soft); overflow:hidden; }
  .cta-band h2 { font:var(--text-display); letter-spacing:var(--track-tight); color:var(--t1); max-width:680px; }
  .cta-band h2 em { font-style:normal; color:var(--yel); }
  .cta-band p { font:400 16px/1.6 var(--font-ui); color:var(--t2); max-width:460px; margin-top:var(--s4); }
  .cta-band .cta { display:flex; gap:var(--s4); margin-top:var(--s8); }
  .cta-band .datum { position:relative; margin-top:var(--s12); height:1px; background:var(--yel); }
  .cta-band .datum::before, .cta-band .datum::after { content:""; position:absolute; top:-4px; width:9px; height:9px; border:1px solid var(--yel); transform:rotate(45deg); background:var(--bg-0); }
  .cta-band .datum::before { left:0; } .cta-band .datum::after { right:0; }

  /* footer */
  footer { padding:var(--s12) 0 var(--s8); }
  footer .cols { display:grid; grid-template-columns:1.6fr 1fr 1fr 1fr; gap:var(--s6); }
  footer .fword { display:flex; align-items:center; gap:10px; font:590 16px/1 var(--font-ui); color:var(--t1); }
  footer .desc { font:400 12.5px/1.6 var(--font-ui); color:var(--t2); max-width:250px; margin-top:var(--s3); }
  footer .mh { font:var(--text-stencil); letter-spacing:var(--track-mono); text-transform:uppercase; color:var(--yel); margin-bottom:var(--s3); }
  footer .col a { display:block; font:400 13px/2 var(--font-ui); color:var(--t2); text-decoration:none; } footer .col a:hover { color:var(--t1); }
  footer .legal { display:flex; gap:var(--s4); margin-top:var(--s8); padding-top:var(--s4); border-top:1px solid var(--border-soft); font:var(--text-mono); font-size:10px; letter-spacing:0.05em; color:var(--t3); }
  footer .legal .r { margin-left:auto; }

  .backlink { position:fixed; left:16px; bottom:16px; z-index:70; background:var(--bg-2); color:var(--yel); border:1px solid var(--border); font:var(--text-mono); font-size:10px; letter-spacing:0.06em; padding:9px 12px; text-decoration:none; }

  @media (max-width:900px){
    .prod { grid-template-columns:1fr; } .prod.rev .pt { order:1; }
    .nums { flex-wrap:wrap; } .nums .nm { flex:1 1 50%; border-left:none; }
    .cases { grid-template-columns:1fr; } .proof .wrap { flex-wrap:wrap; } .proof .names { flex-wrap:wrap; justify-content:flex-start; gap:var(--s4) var(--s6); }
    footer .cols { grid-template-columns:1fr 1fr; }
  }
</style>
</head>
<body>

