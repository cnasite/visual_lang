<script>
(function(){
  var p=document.getElementById('player'); if(!p) return;
  var frames=p.querySelectorAll('.frame'), prog=document.getElementById('vprog'), btn=document.getElementById('playToggle');
  var i=0, n=frames.length, timer=null, dur=4200, playing=false;
  var reduce=window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function show(k){ for(var j=0;j<n;j++) frames[j].classList.toggle('on', j===k);
    if(prog){ prog.style.transition='none'; prog.style.width='0%'; void prog.offsetWidth; if(playing&&!reduce){ prog.style.transition='width '+dur+'ms linear'; prog.style.width='100%'; } } }
  function step(){ i=(i+1)%n; show(i); }
  function play(){ if(playing) return; playing=true; p.classList.add('playing'); show(i); timer=setInterval(step,dur); }
  function pause(){ playing=false; p.classList.remove('playing'); if(timer){ clearInterval(timer); timer=null; } if(prog){ var w=getComputedStyle(prog).width; prog.style.transition='none'; prog.style.width=w; } }
  if(btn) btn.addEventListener('click', function(){ playing ? pause() : play(); });
  show(0);
})();
</script>
