<!-- PLATFORM INTRO -->
<section id="platform" style="padding-bottom:var(--s8)">
  <div class="wrap">
    <div class="shead">
      <span class="ey stencil">The platform</span>
      <h2>Three instruments, <em>one register.</em></h2>
      <p>Built for the people who build — read at every altitude, all measured from one line.</p>
    </div>
  </div>
